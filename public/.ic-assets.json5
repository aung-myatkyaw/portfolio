[
  {
    "match": ".well-known",
    "ignore": false,
    "headers": {
      "Access-Control-Allow-Origin": "*"
    }
  },
  {
    "match": "**/*",
    "security_policy": "standard",
    "headers": {
      "Cache-Control": "public, max-age=31536000, immutable"
    }
  },
  {
    "match": "index.html",
    "security_policy": "standard",
    "headers": {
      "Cache-Control": "no-cache",
      "Content-Security-Policy": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://api.emailjs.com https://icp-api.io; font-src 'self' data:"
    }
  }
]
